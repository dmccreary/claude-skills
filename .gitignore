site
.DS_Store
~$*
.cache
.vscode

# Python bytecode. Regenerated automatically on import, never source. The
# rules below were once scoped to mcp-servers/** only, which let __pycache__
# dirs under plugins/, scripts/, skills/, and src/ get committed.
__pycache__/
*.py[cod]

mcp-servers/**/*.pyc
mcp-servers/**/__pycache__/
mcp-servers/**/*.egg-info/
mcp-servers/**/dist/
mcp-servers/**/build/
mcp-servers/**/.venv/
mcp-servers/**/venv/
.claude/activity-logs/
.claude/settings.local.json
.claude/worktrees/

# Per-turn tracking files used by the auto-commit-claude-skills hooks.
# .claude-pending-commit.txt holds the commit message Claude writes during
# the turn; .claude-pending-files.txt holds the list of file paths Claude
# edited via Edit/Write/MultiEdit (populated by track-claude-skills-edits.sh).
# Both are deleted by the Stop hook after a successful commit. Never commit
# either file.
.claude-pending-commit.txt
.claude-pending-files.txt
