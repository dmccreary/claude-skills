#!/bin/bash
# bk-install-social-override-plugin
#
# Installs the social_override hook for mkdocs-material into the current
# directory. The hook injects og:title, og:description, og:image,
# og:type, og:url, twitter:card, twitter:title, twitter:description,
# and twitter:image meta tags on every page, using each page's
# `title:`, `description:`, and `image:` frontmatter (with site-wide
# fallbacks to `site_name`, `site_description`, and `img/cover.png`).
#
# This is the default social-preview path for intelligent textbooks
# because it has NO system dependencies — unlike the full
# `mkdocs-material[imaging]` social plugin, which requires Cairo.
# When that plugin IS enabled alongside this hook, the hook also
# replaces the plugin's auto-generated /assets/images/social/ image
# URLs with the declared cover image, so social shares brand the book
# rather than a per-page generated card.
#
# This installer uses the mkdocs `hooks:` mechanism (a file-path
# reference in mkdocs.yml), NOT a Python entry-point plugin. Reason:
# when multiple sibling MkDocs projects install editable packages that
# all claim the top-level `plugins` module name (which is what the old
# setup.py/entry_point approach did), Python's import resolution
# silently picks whichever project's `plugins/social_override.py`
# landed first in sys.meta_path — usually the wrong one. The `hooks:`
# mechanism loads a file by absolute path and sidesteps the collision
# entirely.
#
# See skills/book-installer/references/social-media-preview.md for the
# canonical reference.

# Colors for output
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
RED='\033[0;31m'
NC='\033[0m' # No Color

# Check if BK_HOME is set
if [ -z "$BK_HOME" ]; then
    echo -e "${RED}Error: BK_HOME environment variable is not set.${NC}"
    echo "Please set BK_HOME to the root directory of your claude-skills repository."
    echo "Example: export BK_HOME=$HOME/Documents/ws/claude-skills"
    exit 1
fi

# Check if BK_HOME directory exists
if [ ! -d "$BK_HOME" ]; then
    echo -e "${RED}Error: BK_HOME directory does not exist: $BK_HOME${NC}"
    exit 1
fi

echo -e "${BLUE}════════════════════════════════════════════════════════════════${NC}"
echo -e "${GREEN}Installing Social Override Hook${NC}"
echo -e "${BLUE}════════════════════════════════════════════════════════════════${NC}"
echo -e "BK_HOME:    ${YELLOW}$BK_HOME${NC}"
echo -e "Target dir: ${YELLOW}$(pwd)${NC}"
echo ""

# Check if mkdocs.yml exists in current directory
if [ ! -f "mkdocs.yml" ]; then
    echo -e "${YELLOW}⚠ Warning: mkdocs.yml not found in current directory${NC}"
    echo "This script should be run from the root of an MkDocs project."
    echo ""
    read -p "Continue anyway? (y/N) " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        echo "Installation cancelled."
        exit 0
    fi
fi

# Detect and clean up any old entry-point-plugin install in this project.
# Older versions of this script created setup.py + egg-info + plugins/__init__.py
# and ran `pip install -e .`. If we find those artifacts, remove them
# before writing the hook file, otherwise the stale package can still
# win at import time.
cleaned_old=0
if [ -f "setup.py" ] && grep -q "social_override" setup.py 2>/dev/null; then
    echo -e "${YELLOW}Removing old entry-point-plugin setup.py...${NC}"
    rm -f setup.py
    cleaned_old=1
fi
if [ -d "social_override.egg-info" ]; then
    echo -e "${YELLOW}Removing old social_override.egg-info/...${NC}"
    rm -rf social_override.egg-info
    cleaned_old=1
fi
if [ -f "plugins/__init__.py" ] && grep -q "SocialOverridePlugin" plugins/__init__.py 2>/dev/null; then
    echo -e "${YELLOW}Removing old plugins/__init__.py...${NC}"
    rm -f plugins/__init__.py
    cleaned_old=1
fi
if command -v pip &> /dev/null && pip show social_override &> /dev/null; then
    echo -e "${YELLOW}Uninstalling old editable social_override package...${NC}"
    pip uninstall -y social_override
    cleaned_old=1
fi
if [ "$cleaned_old" = "1" ]; then
    echo ""
fi

# Create directories
echo -e "${BLUE}Creating plugins directory...${NC}"
mkdir -p plugins

# Create the hook file (module-level functions, NOT a BasePlugin subclass)
echo -e "${GREEN}✓${NC} Creating plugins/social_override.py..."
cat > plugins/social_override.py << 'EOL'
"""MkDocs hook that injects Open Graph and Twitter Card meta tags into
every rendered page using the page's frontmatter.

Loaded via the `hooks:` entry in mkdocs.yml, not as a plugin -- this
avoids collisions with other projects that also install a package
called `social_override` or a top-level module called `plugins`.

Frontmatter fields read (per page):
    title         -- falls back to the H1/page.title
    description   -- falls back to site_description
    image         -- path under docs/ (e.g. img/cover.png); falls back to
                     site-wide default `img/cover.png`

The hook emits absolute URLs by joining `site_url` with the image path,
so the og:image / twitter:image tags work for crawlers and the
bk-check-social-cover verifier (which HEAD-requests the image URL).

If the social plugin (mkdocs-material[imaging]) is enabled, this hook
also replaces its auto-generated /assets/images/social/ tags with the
declared cover image.
"""

import re

DEFAULT_IMAGE = "img/cover.png"


def _absolute_image_url(site_url, image_path):
    if image_path.startswith(("http://", "https://")):
        return image_path
    return site_url.rstrip("/") + "/" + image_path.lstrip("/")


def _meta_tag(prop, content, attr="property"):
    return f'<meta {attr}="{prop}" content="{content}">'


def on_post_page(html, page, config, **kwargs):
    site_url = config.get("site_url") or ""
    if not site_url:
        return html

    title = (page.meta or {}).get("title") or page.title or config.get("site_name", "")
    description = (page.meta or {}).get("description") or config.get("site_description", "")
    image = (page.meta or {}).get("image") or DEFAULT_IMAGE
    image_url = _absolute_image_url(site_url, image)

    # Replace social-plugin-emitted /assets/images/social/ tags first.
    og_social = re.compile(
        r'<meta\s+property="og:image"\s+content="[^"]*/assets/images/social/[^"]*"[^>]*>'
    )
    html = og_social.sub(_meta_tag("og:image", image_url), html)

    tw_social = re.compile(
        r'<meta\s+(?:property|name)="twitter:image"\s+content="[^"]*/assets/images/social/[^"]*"[^>]*>'
    )
    html = tw_social.sub(_meta_tag("twitter:image", image_url, attr="name"), html)

    # Inject any tags that are still missing, immediately before </head>.
    injections = []
    if not re.search(r'<meta\s+property="og:title"', html):
        injections.append(_meta_tag("og:title", title))
    if not re.search(r'<meta\s+property="og:description"', html):
        injections.append(_meta_tag("og:description", description))
    if not re.search(r'<meta\s+property="og:image"', html):
        injections.append(_meta_tag("og:image", image_url))
    if not re.search(r'<meta\s+property="og:type"', html):
        injections.append(_meta_tag("og:type", "website"))
    if not re.search(r'<meta\s+property="og:url"', html):
        page_url = site_url.rstrip("/") + "/" + (page.url or "").lstrip("/")
        injections.append(_meta_tag("og:url", page_url))

    if not re.search(r'<meta\s+(?:property|name)="twitter:card"', html):
        injections.append(_meta_tag("twitter:card", "summary_large_image", attr="name"))
    if not re.search(r'<meta\s+(?:property|name)="twitter:title"', html):
        injections.append(_meta_tag("twitter:title", title, attr="name"))
    if not re.search(r'<meta\s+(?:property|name)="twitter:description"', html):
        injections.append(_meta_tag("twitter:description", description, attr="name"))
    if not re.search(r'<meta\s+(?:property|name)="twitter:image"', html):
        injections.append(_meta_tag("twitter:image", image_url, attr="name"))

    if injections:
        html = html.replace("</head>", "  " + "\n  ".join(injections) + "\n</head>", 1)

    return html
EOL

echo ""
echo -e "${BLUE}════════════════════════════════════════════════════════════════${NC}"
echo -e "${GREEN}Installation complete!${NC}"
echo ""
echo -e "${YELLOW}Next steps:${NC}"
echo ""
echo "1. In mkdocs.yml, add a top-level 'hooks:' block (peer of 'plugins:',"
echo "   NOT nested under it):"
echo ""
echo -e "${BLUE}hooks:${NC}"
echo -e "  ${GREEN}- plugins/social_override.py${NC}"
echo ""
echo "   The Material 'social' plugin is OPTIONAL. This hook works on its"
echo "   own and has no Cairo dependency. If 'social' is also enabled, the"
echo "   hook will automatically replace its generated /assets/images/social/"
echo "   URLs with your declared cover image."
echo ""
echo "2. Make sure 'site_url:' is set in mkdocs.yml (the hook emits absolute"
echo "   URLs by joining site_url + image path)."
echo ""
echo "3. Confirm docs/index.md frontmatter declares title, description, and"
echo "   image (relative to docs/):"
echo ""
echo -e "${BLUE}---${NC}"
echo "title: My Book — Subtitle (aim for 40-60 chars)"
echo "description: One- or two-sentence book description (55-200 chars)."
echo -e "${GREEN}image: img/cover.png${NC}"
echo -e "${BLUE}---${NC}"
echo ""
echo "   The hook defaults image to 'img/cover.png' site-wide, so chapter"
echo "   pages can omit 'image:' and still get the book cover for unfurls."
echo ""
echo "4. Rebuild and verify all nine social meta tags are emitted:"
echo ""
echo -e "${BLUE}   mkdocs build${NC}"
echo -e "${BLUE}   grep -E '<meta\\s+(property|name)=\"(og|twitter)' site/index.html${NC}"
echo ""
echo "   Expected: og:title, og:description, og:image, og:type, og:url,"
echo "   twitter:card, twitter:title, twitter:description, twitter:image."
echo "   og:image and twitter:image URLs should be absolute (start with"
echo "   site_url)."
echo ""
echo "5. After 'mkdocs gh-deploy', verify the live site:"
echo ""
echo -e "${BLUE}   ~/.local/bin/bk-check-social-cover <project-name>${NC}"
echo ""
echo "   The verifier requires the image basename to be exactly 'cover.png'"
echo "   and HEAD-requests the URL to confirm it returns HTTP 200."
echo ""
echo -e "${BLUE}════════════════════════════════════════════════════════════════${NC}"
