#!/usr/bin/env bash
# Install this repository's active skills into ~/.codex/skills.

set -euo pipefail

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
RED='\033[0;31m'
NC='\033[0m'

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="${BK_HOME:-$(cd "$SCRIPT_DIR/.." && pwd)}"
SKILLS_DIR="$REPO_ROOT/skills"
COMMANDS_DIR="$REPO_ROOT/commands"
TARGET_DIR="$HOME/.codex/skills"

if [[ ! -d "$SKILLS_DIR" ]]; then
    printf '%bError: skills directory does not exist: %s%b\n' "$RED" "$SKILLS_DIR" "$NC" >&2
    exit 1
fi

# Active skills live directly under skills/ and contain SKILL.md. This omits
# skills/archived/, whose retired skills are routed through active meta-skills.
skill_dirs=()
shopt -s nullglob
for skill_file in "$SKILLS_DIR"/*/SKILL.md; do
    skill_dirs+=("$(dirname "$skill_file")")
done
shopt -u nullglob

if (( ${#skill_dirs[@]} == 0 )); then
    printf '%bError: no active skills found in %s%b\n' "$RED" "$SKILLS_DIR" "$NC" >&2
    exit 1
fi

is_active_skill() {
    local candidate=$1
    local skill_dir

    for skill_dir in "${skill_dirs[@]}"; do
        if [[ "$(basename "$skill_dir")" == "$candidate" ]]; then
            return 0
        fi
    done
    return 1
}

printf '%bInstalling Codex skills%b\n' "$BLUE" "$NC"
printf 'Source: %b%s%b\n' "$YELLOW" "$SKILLS_DIR" "$NC"
printf 'Target: %b%s%b\n\n' "$YELLOW" "$TARGET_DIR" "$NC"

mkdir -p "$TARGET_DIR"

# Remove every broken symlink in the Codex skills directory, including hidden
# entries. Also remove live links managed by this repository when their skill
# has since been archived, consolidated, renamed, or deleted.
removed_count=0
shopt -s nullglob dotglob
target_entries=("$TARGET_DIR"/*)
shopt -u nullglob dotglob

for link in "${target_entries[@]}"; do
    [[ -L "$link" ]] || continue

    link_name=$(basename "$link")
    link_target=$(readlink "$link")

    if [[ ! -e "$link" ]]; then
        rm -- "$link"
        printf '%bRemoved broken link:%b %s -> %s\n' "$YELLOW" "$NC" "$link_name" "$link_target"
        ((++removed_count))
    elif [[ "$link_target" == "$SKILLS_DIR/"* ]] && ! is_active_skill "$link_name"; then
        rm -- "$link"
        printf '%bRemoved stale repository link:%b %s -> %s\n' "$YELLOW" "$NC" "$link_name" "$link_target"
        ((++removed_count))
    fi
done

if (( removed_count == 0 )); then
    printf '%bNo broken or stale symlinks found.%b\n' "$GREEN" "$NC"
fi

printf '\n%bInstalling %d active skills...%b\n' "$BLUE" "${#skill_dirs[@]}" "$NC"
installed_count=0
unchanged_count=0
conflict_count=0
converted_count=0

for skill_dir in "${skill_dirs[@]}"; do
    skill_name=$(basename "$skill_dir")
    target_link="$TARGET_DIR/$skill_name"

    if [[ -L "$target_link" ]] && [[ "$(readlink "$target_link")" == "$skill_dir" ]]; then
        printf '%bAlready installed:%b %s\n' "$GREEN" "$NC" "$skill_name"
        ((++unchanged_count))
        continue
    fi

    if [[ -L "$target_link" ]]; then
        rm -- "$target_link"
    elif [[ -e "$target_link" ]]; then
        printf '%bConflict:%b %s exists and is not a symlink; leaving it unchanged.\n' \
            "$RED" "$NC" "$target_link" >&2
        ((++conflict_count))
        continue
    fi

    ln -s "$skill_dir" "$target_link"
    printf '%bInstalled:%b %s -> %s\n' "$GREEN" "$NC" "$skill_name" "$skill_dir"
    ((++installed_count))
done

# Codex Desktop uses skills for reusable workflows rather than repository
# command files. Convert selected command sources into managed skill wrappers
# without duplicating their content. Including "/ibook" in the skill's
# description allows implicit matching when that text reaches the model; the
# supported explicit Desktop invocation remains "$ibook".
install_command_as_skill() {
    local command_name=$1
    local command_file="$COMMANDS_DIR/$command_name.md"
    local target_skill="$TARGET_DIR/$command_name"
    local marker="$target_skill/.bk-command-source"
    local skill_link="$target_skill/SKILL.md"
    local metadata_file="$target_skill/agents/openai.yaml"

    if [[ ! -f "$command_file" ]]; then
        printf '%bMissing command source:%b %s\n' "$RED" "$NC" "$command_file" >&2
        ((++conflict_count))
        return
    fi

    if ! grep -qx "name: $command_name" "$command_file" || \
       ! grep -q '^description: .' "$command_file"; then
        printf '%bInvalid command skill metadata:%b %s must declare name and description.\n' \
            "$RED" "$NC" "$command_file" >&2
        ((++conflict_count))
        return
    fi

    if is_active_skill "$command_name"; then
        printf '%bSkipping command conversion:%b %s is already an active skill.\n' \
            "$YELLOW" "$NC" "$command_name"
        return
    fi

    if [[ -L "$target_skill" ]]; then
        rm -- "$target_skill"
    elif [[ -e "$target_skill" ]] && [[ ! -d "$target_skill" ]]; then
        printf '%bConflict:%b %s exists and is not a directory; leaving it unchanged.\n' \
            "$RED" "$NC" "$target_skill" >&2
        ((++conflict_count))
        return
    elif [[ -d "$target_skill" ]] && \
         { [[ ! -f "$marker" ]] || [[ "$(<"$marker")" != "$command_file" ]]; }; then
        printf '%bConflict:%b %s is not managed by this installer; leaving it unchanged.\n' \
            "$RED" "$NC" "$target_skill" >&2
        ((++conflict_count))
        return
    fi

    mkdir -p "$target_skill/agents"
    printf '%s\n' "$command_file" > "$marker"

    if [[ -L "$skill_link" ]] || [[ -e "$skill_link" ]]; then
        rm -- "$skill_link"
    fi
    ln -s "$command_file" "$skill_link"

    # UI metadata follows the skill-creator format. Explicit invocation uses
    # $ibook; implicit invocation remains enabled for prompts containing
    # "/ibook" or natural-language requests matching the description.
    {
        printf '%s\n' 'interface:'
        printf '%s\n' '  display_name: "Intelligent Textbook Runbook"'
        printf '%s\n' '  short_description: "Find the next textbook build skill"'
        printf '%s\n' '  default_prompt: "Use $ibook to assess this textbook project and recommend the next skill."'
        printf '%s\n' 'policy:'
        printf '%s\n' '  allow_implicit_invocation: true'
    } > "$metadata_file"

    printf '%bConverted command to skill:%b %s -> %s\n' \
        "$GREEN" "$NC" "$command_file" "$target_skill"
    ((++converted_count))
}

printf '\n%bConverting Codex command workflows to skills...%b\n' "$BLUE" "$NC"
install_command_as_skill ibook

# A successful run must leave no broken links anywhere in ~/.codex/skills and
# must install every active repository skill at its expected path.
broken_links=()
while IFS= read -r -d '' link; do
    if [[ ! -e "$link" ]]; then
        broken_links+=("$link")
    fi
done < <(find "$TARGET_DIR" -type l -print0)

printf '\n%bSummary:%b %d installed, %d already current, %d removed\n' \
    "$BLUE" "$NC" "$installed_count" "$unchanged_count" "$removed_count"
printf '%bCommand conversions:%b %d\n' "$BLUE" "$NC" "$converted_count"

if (( conflict_count > 0 )); then
    printf '%bInstallation incomplete: %d non-symlink conflict(s).%b\n' \
        "$RED" "$conflict_count" "$NC" >&2
    exit 1
fi

if (( ${#broken_links[@]} > 0 )); then
    printf '%bInstallation incomplete: broken symlinks remain:%b\n' "$RED" "$NC" >&2
    printf '  %s\n' "${broken_links[@]}" >&2
    exit 1
fi

printf '%bCodex skill installation is current; no broken symlinks remain.%b\n' "$GREEN" "$NC"
